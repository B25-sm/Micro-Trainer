# =======================================================
# 🎓 MICROTRAINER CENTRAL PLATFORM - ENVIRONMENT CONFIG
# =======================================================

# Server Configuration
PORT=6000
NODE_ENV=development

# MongoDB Configuration
# Local MongoDB: mongodb://localhost:27017/microtrainer-platform
# MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/microtrainer-platform
MONGODB_URI=mongodb://localhost:27017/microtrainer-platform

# CORS Configuration (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5000

# Admin Authentication
ADMIN_USERNAME=admin
# Default password: "admin123" (CHANGE THIS IN PRODUCTION!)
# To generate new hash: node -e "const bcrypt = require('bcryptjs'); bcrypt.hash('your_password', 10).then(console.log);"
ADMIN_PASSWORD_HASH=$2a$10$8K1p/a0dL3LKzOWR7N.Nje.xjNvZr5tGxvzVxvxvxvxvxvxvxvxvu

# JWT Configuration
JWT_SECRET=microtrainer-platform-secret-key-change-in-production
JWT_EXPIRY=24h
